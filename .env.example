# ─── Required API Keys ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ─── API Authentication ───────────────────────────────────────────────────────
# Set a strong random secret for the X-API-Key header
API_KEY=changeme-replace-with-a-strong-random-secret

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change-this-strong-password
# Full connection URL used by the backend (set automatically in docker-compose)
DATABASE_URL=postgresql+asyncpg://postgres:change-this-strong-password@localhost:5432/ragdb

# ─── Model Configuration ──────────────────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-20250514
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# ─── RAG Settings ─────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K=5
MIN_SIMILARITY=0.3

# ─── Observability ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
AUDIT_LOG_PATH=/tmp/audit.jsonl

# ─── SLOs ─────────────────────────────────────────────────────────────────────
RETRIEVAL_SLO_P95_MS=3000
E2E_SLO_P95_MS=8000

# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_API_KEY=changeme-replace-with-a-strong-random-secret
